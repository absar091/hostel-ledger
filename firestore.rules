rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can read and write their own user document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Groups - authenticated users can read and write
    match /groups/{groupId} {
      allow read, write: if request.auth != null;
    }
    
    // User groups - users can only access their own groups
    match /userGroups/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Transactions - authenticated users can read and write
    match /transactions/{transactionId} {
      allow read, write: if request.auth != null;
    }
    
    // User transactions - users can only access their own transactions
    match /userTransactions/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Verification codes - allow read/write for unauthenticated users (needed for signup)
    match /verificationCodes/{codeId} {
      allow read, write: if true;
      allow delete: if true;
    }
  }
}